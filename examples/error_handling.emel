-- Error handling with `throws` / `throw` / `?` / `try` / `catch`, plus enums,
-- `match`, and `Option` (spec 0005 / 0011). The error channel is expressed with
-- `throws E`; there is no built-in `Result` type.
--
-- Run with the js-node backend, which lowers errors to native exceptions:
--   emela build --backend js-node examples/error_handling.emel -o out.js
--   node out.js     # prints 51

enum ParseError {
    Empty
    BadDigit
}

-- A throwing function declares its error type after the return type.
fn parse_digit(s: String) -> Int throws ParseError uses {} {
    throw ParseError::BadDigit
}

-- `try` / `catch` handles the error, resolving the throws channel so this
-- function itself is non-throwing.
fn parse_or(s: String, fallback: Int) -> Int uses {} {
    try {
        parse_digit(s)
    } catch {
        ParseError::Empty -> 0
        ParseError::BadDigit -> fallback
    }
}

-- `match` over an enum must be exhaustive.
fn error_name(e: ParseError) -> String uses {} {
    match e {
        Empty -> "empty"
        BadDigit -> "bad digit"
    }
}

-- The absence of a value is `Option<T>`, not an error.
fn unwrap_or(opt: Option<Int>, fallback: Int) -> Int uses {} {
    match opt {
        Some(value) -> value
        None -> fallback
    }
}

fn main() -> Int uses {} {
    let parsed = parse_or("x", 42)
    let present = unwrap_or(Some(8), 0)
    let absent = unwrap_or(None, 1)
    parsed + present + absent
}
